# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Places API key, for real Google reviews on clinic profile pages.
# Requires a Google Cloud project with billing enabled and the "Places API"
# enabled. Get a key at https://console.cloud.google.com/apis/credentials
# The site works fine without this — the reviews section shows a friendly
# "not connected yet" message instead.
GOOGLE_PLACES_API_KEY=

# Resend API key, to email quote-funnel submissions to your team. Without
# this, inquiries are NOT delivered anywhere — see /api/leads in index.js.
# Get a key at https://resend.com/api-keys after verifying your domain there.
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=info@hospigo.com
LEAD_FROM_EMAIL=quotes@hospigo.com

# GA4 Data API, for real per-article pageview counts on the News pages
# (client/src/content/news.ts "views" numbers). This is separate from the
# VITE_GA_MEASUREMENT_ID that sends tracking data TO Google Analytics — this
# is what reads real numbers back OUT. Without these two set, view counts
# fall back to the self-hosted counter (server/ga4.js has the full setup
# comment). GA4_PROPERTY_ID is the numeric property ID from GA4 Admin >
# Property details. GOOGLE_SERVICE_ACCOUNT_JSON is the full contents of a
# service-account key JSON file (one line, from Google Cloud Console), for a
# service account granted Viewer access on the GA4 property.
GA4_PROPERTY_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Optional overrides
HOSPIGO_SERVER_PORT=3001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
