# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Places API key, for real Google reviews on clinic profile pages.
# Requires a Google Cloud project with billing enabled and the "Places API"
# enabled. Get a key at https://console.cloud.google.com/apis/credentials
# The site works fine without this — the reviews section shows a friendly
# "not connected yet" message instead.
GOOGLE_PLACES_API_KEY=

# Optional overrides
HOSPIGO_SERVER_PORT=3001
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
